# ================================
# KLIJENTOMAT — Environment Variables
# Kopiraj u .env i popuni vrednosti
# ================================

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://klijentomat:changeme@postgres/klijentomat
POSTGRES_USER=klijentomat
POSTGRES_PASSWORD=changeme

# --- REDIS / CELERY ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- SECURITY ---
# Generiši: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 dana

# --- AI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- EMAIL (SendGrid) ---
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@klijentomat.rs
SENDGRID_FROM_NAME=Klijentomat

# --- TRACKING ---
# Gde se hostuje tracking piksel
TRACKING_BASE_URL=https://track.klijentomat.rs

# --- GOOGLE ---
# https://console.cloud.google.com → Enable Places API + OAuth2
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- WHATSAPP (Meta) ---
# https://developers.facebook.com → WhatsApp Business API
META_ACCESS_TOKEN=...
META_PHONE_NUMBER_ID=...
META_WEBHOOK_VERIFY_TOKEN=your-webhook-token

# --- STRIPE ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TEHNICAR=price_...      # 39 EUR/mes
STRIPE_PRICE_KOMERCIJALISTA=price_... # 79 EUR/mes
STRIPE_PRICE_SEFICA=price_...        # 179 EUR/mes

# --- APP ---
APP_NAME=Klijentomat
APP_URL=https://app.klijentomat.rs
ENVIRONMENT=development  # development | production
DEBUG=true
